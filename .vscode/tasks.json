{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-frontend",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"--dir",
				"frontend",
				"build"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Start local stack 8080",
			"type": "shell",
			"command": "docker compose -f docker-compose.local.yml up --build -d",
			"group": "build"
		},
		{
			"label": "docker-up-local",
			"type": "shell",
			"command": "docker compose -f docker-compose.local.yml up -d --build"
		}
	]
}